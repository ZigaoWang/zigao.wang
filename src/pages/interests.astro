---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const cameras = [
	{ name: 'Canon AE-1 Program', meta: '35mm SLR · FD 50mm f/1.8', img: '/cameras/canon-ae1.webp', url: 'https://avoidxray.com/cameras/cmjz3yhxh00076w5vft97mlfu' },
	{ name: 'Snapic A1', meta: 'Kodak point-and-shoot · 25mm', img: '/cameras/snapic-a1.webp', url: 'https://avoidxray.com/cameras/cmkkzyoqa000b6wi7ew4bskje' },
	{ name: 'Sprocket Rocket', meta: 'Lomography · 35mm panoramic', img: '/cameras/sprocket-rocket.webp', url: 'https://avoidxray.com/cameras/cmm2pgqqa0001h1ep1qd7h7qg' },
];

const gear = [
	{ name: 'Tenor saxophone', meta: 'Cheap one, but good enough to play.', img: '/gear/tenor.webp', url: null },
	{ name: 'Akai MPK Mini 4', meta: 'MIDI controller, learning live looping.', img: '/gear/akai-mpk-mini-4.png', url: 'https://www.akaipro.com/mpk-mini-4/' },
	{ name: 'AT-LP60XBTa', meta: 'Belt-drive turntable for vinyl.', img: '/gear/audio-technica-at-lp60xbt.webp', url: 'https://www.audio-technica.com.hk/index.php?op=productdetails&pid=1459&cid=30&sid=52&lang=eng' },
];

const books = (await getCollection('blog'))
	.filter((p) => p.data.category === 'Books')
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Interests — ${SITE_TITLE}`} description="Film photography, music, running, drama, building, reading, travel." />
	</head>
	<body>
		<Header />
		<main>
			<article class="page">
				<h1>Interests</h1>

				<section>
					<h2>Film photography</h2>
					<p>
						I shoot film and run <a href="https://avoidxray.com" target="_blank" rel="noreferrer">AvoidXray</a>, a community for analog photographers. My photos live at <a href="https://avoidxray.com/zigaowang" target="_blank" rel="noreferrer">avoidxray.com/zigaowang</a>.
					</p>
					<div class="gear three">
						{cameras.map((c) => (
							<a class="g-card" href={c.url} target="_blank" rel="noreferrer">
								<div class="g-photo"><img src={c.img} alt={c.name} loading="lazy" /></div>
								<div class="g-meta">
									<h3>{c.name}</h3>
									<p>{c.meta}</p>
								</div>
							</a>
						))}
					</div>
				</section>

				<section>
					<h2>Music</h2>
					<p>
						I play tenor saxophone in my school's jazz band. Off-stage I'm learning live looping on a small controller, and I spin vinyl on a belt-drive turntable.
					</p>
					<div class="gear three">
						{gear.map((g) => (
							g.url ? (
								<a class="g-card" href={g.url} target="_blank" rel="noreferrer">
									<div class="g-photo"><img src={g.img} alt={g.name} loading="lazy" /></div>
									<div class="g-meta">
										<h3>{g.name}</h3>
										<p>{g.meta}</p>
									</div>
								</a>
							) : (
								<div class="g-card no-link">
									<div class="g-photo"><img src={g.img} alt={g.name} loading="lazy" /></div>
									<div class="g-meta">
										<h3>{g.name}</h3>
										<p>{g.meta}</p>
									</div>
								</div>
							)
						))}
					</div>
				</section>

				<section>
					<h2>Running &amp; fitness</h2>
					<p>Long runs, some weight training, basketball with friends.</p>
				</section>

				<section>
					<h2>Drama</h2>
					<p>
						I act in school productions. In 2025 I performed as a lead at the <a href="https://www.edfringe.com" target="_blank" rel="noreferrer">Edinburgh Fringe</a> and got a 4-star review. Currently studying IGCSE Drama.
					</p>
				</section>

				<section>
					<h2>Building</h2>
					<p>
						I ship iOS apps and web projects — see the <a href="/">projects</a> on the home page. I also help organize <a href="https://adventure-x.org" target="_blank" rel="noreferrer">AdventureX</a>, China's largest student hackathon.
					</p>
				</section>

				<section>
					<h2>Reading</h2>
					<p>
						Books I've reviewed on <a href="/blog">my blog</a>:
					</p>
					{books.length > 0 && (
						<div class="books">
							{books.map((b) => (
								<a href={`/blog/${b.id}/`} class="book">
									{b.data.heroImage && (
										<div class="b-cover">
											<Image src={b.data.heroImage} alt={b.data.title} width={180} height={270} />
										</div>
									)}
									<div class="b-meta">
										<h3>{b.data.title}</h3>
										{b.data.author && <p class="b-author">{b.data.author}</p>}
									</div>
								</a>
							))}
						</div>
					)}
				</section>

				<section>
					<h2>Travel</h2>
					<p>I like to travel.</p>
				</section>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main { padding-top: 3.5rem; padding-bottom: 4.5rem; }

	.page h1 {
		font-family: var(--font-serif);
		font-weight: 400;
		font-size: 2.4rem;
		letter-spacing: -0.025em;
		margin: 0 0 2.5rem;
	}

	.page section {
		margin-top: 3rem;
	}
	.page section:first-of-type { margin-top: 0; }

	.page h2 {
		font-family: var(--font-serif);
		font-weight: 400;
		font-size: 1.5rem;
		letter-spacing: -0.015em;
		margin: 0 0 0.7rem;
	}
	.page section > p {
		font-size: 1rem;
		line-height: 1.75;
		color: var(--text);
		margin: 0 0 1.25rem;
	}
	.page section > p:last-child { margin-bottom: 0; }

	.gear {
		display: grid;
		gap: 1rem;
		margin-top: 0.5rem;
	}
	.gear.three { grid-template-columns: repeat(3, 1fr); }

	.g-card {
		display: flex;
		flex-direction: column;
		background: var(--surface);
		border: 1px solid var(--border);
		text-decoration: none;
		color: var(--text);
	}
	a.g-card:hover { border-color: #333; }
	.g-photo {
		height: 220px;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1.25rem;
		background: transparent;
	}
	.g-photo img {
		max-width: 100%;
		max-height: 100%;
		object-fit: contain;
		border-radius: 0;
	}
	.g-meta {
		padding: 0.85rem 1rem 0.95rem;
		border-top: 1px solid var(--border);
	}
	.g-meta h3 {
		font-family: var(--font-serif);
		font-size: 1rem;
		font-weight: 400;
		margin: 0 0 0.2rem;
		line-height: 1.3;
	}
	.g-meta p {
		font-size: 0.84rem;
		color: var(--text-secondary);
		margin: 0;
		line-height: 1.5;
	}

	.books {
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		gap: 1.25rem;
		margin-top: 0.75rem;
	}
	.book {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: var(--text);
	}
	.b-cover {
		aspect-ratio: 2 / 3;
		overflow: hidden;
		margin-bottom: 0.6rem;
		box-shadow: 0 2px 8px rgba(0,0,0,0.35);
	}
	.b-cover :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		display: block;
	}
	.book:hover .b-cover {
		box-shadow: 0 4px 14px rgba(0,0,0,0.5);
	}
	.b-meta h3 {
		font-family: var(--font-serif);
		font-size: 0.92rem;
		font-weight: 400;
		margin: 0 0 0.15rem;
		line-height: 1.3;
	}
	.b-author {
		font-size: 0.78rem;
		color: var(--text-secondary);
		margin: 0;
		line-height: 1.4;
	}

	@media (max-width: 720px) {
		.page h1 { font-size: 2rem; }
		.gear.three { grid-template-columns: 1fr 1fr; }
		.g-photo { height: 180px; }
		.books { grid-template-columns: repeat(3, 1fr); }
	}
	@media (max-width: 520px) {
		.gear.three { grid-template-columns: 1fr; gap: 0.65rem; }
		.g-card { flex-direction: row; align-items: stretch; }
		.g-photo {
			height: auto;
			width: 110px;
			flex-shrink: 0;
			padding: 0.7rem;
		}
		.g-meta {
			border-top: none;
			border-left: 1px solid var(--border);
			padding: 0.75rem 0.9rem;
			flex: 1;
			display: flex;
			flex-direction: column;
			justify-content: center;
		}
		.g-meta h3 { font-size: 0.98rem; }
		.g-meta p { font-size: 0.82rem; }
		.books { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
	}
</style>
