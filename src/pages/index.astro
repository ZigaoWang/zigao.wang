---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import StarRating from '../components/StarRating.astro';
import { getReadTime } from '../utils/readTime';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const latestPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);

const featuredProjects = [
	{
		name: 'AvoidXray',
		url: 'https://avoidxray.com',
		src: 'https://github.com/ZigaoWang/avoidxray.com',
		img: '/projects/avoidxray.webp',
		imgPosition: 'top',
		tagline: 'A community website for film photographers.',
		detail: 'Browse and share full-res scans, sorted by camera and film stock, so you can see exactly what any film looks like before you shoot it.',
	},
	{
		name: 'z1.chat',
		url: 'https://z1.chat',
		src: 'https://github.com/ZigaoWang/z1.chat',
		img: '/projects/z1chat.webp',
		imgPosition: 'top',
		tagline: 'A full AI chat platform built from scratch.',
		detail: 'Multiple models, cross-chat memory, web search, a sandbox that runs code, and artifacts that render HTML and diagrams. Pay-as-you-go, no subscription.',
	},
];

const iosProjects = [
	{ name: 'Zap Notes', url: 'https://apps.apple.com/us/app/zap-notes/id6740298881', urlLabel: 'App Store', desc: 'A multi-input AI note-taking app.', src: 'https://github.com/ZigaoWang/ZapNotesApp' },
	{ name: 'Zap Know AI', url: 'https://apps.apple.com/us/app/zap-know-ai/id6745419831', urlLabel: 'App Store', desc: 'An AI research app backed by real papers.', src: 'https://github.com/ZigaoWang/ZapKnowAI-iOS' },
	{ name: 'Go or No', url: 'https://apps.apple.com/us/app/go-or-no/id6744859953', urlLabel: 'App Store', desc: 'An AI-powered AR navigation app for visually impaired users.', src: 'https://github.com/ZigaoWang/go-or-no' },
	{ name: 'Out Loud', url: 'https://out-loud.app/', urlLabel: 'Visit site', desc: 'A voice recording app with real-time transcription and AI analysis.', src: 'https://github.com/ZigaoWang/out-loud-app' },
];

const gearPreview = [
	{ name: 'Canon AE-1 Program', meta: '35mm SLR', img: '/cameras/canon-ae1.webp' },
	{ name: 'Tenor saxophone', meta: 'Jazz band', img: '/gear/tenor.webp' },
	{ name: 'AT-LP60XBTa', meta: 'Vinyl turntable', img: '/gear/audio-technica-at-lp60xbt.webp' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} — Student Developer & Maker in Shanghai`} description={SITE_DESCRIPTION} image="/bg.jpg" />
	</head>
	<body>
		<div class="hero">
			<div class="hero-overlay"></div>
			<div class="hero-fade"></div>
			<div class="hero-content">
				<div class="hero-text">
					<h1>Zigao Wang</h1>
					<p class="pron">
						<span>zuh-GOW WONG</span>
						<button class="play-btn" id="play-pron" aria-label="Play name pronunciation">
							<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z" fill="currentColor"/></svg>
						</button>
					</p>
					<p class="tagline">Student developer and maker in Shanghai.</p>
				</div>
				<img class="profile-pic" src="/profile.png" alt="Zigao Wang" width="140" height="140" />
			</div>
		</div>
		<audio id="pron-audio" src="/pronunciation.mp3" preload="none"></audio>

		<main>
			<section class="section">
				<h2>Projects</h2>
				<div class="proj-featured">
					{featuredProjects.map((p) => (
						<div class="feat-card">
							<a class="feat-card-link" href={p.url} target="_blank" rel="noreferrer" aria-label={`Visit ${p.name}`}></a>
							<div class="feat-img">
								<img src={p.img} alt={`${p.name} screenshot`} loading="lazy" style={`object-position: ${p.imgPosition}`} />
							</div>
							<div class="feat-body">
								<div class="feat-title-row">
									<span class="feat-name">{p.name}</span>
									<span class="feat-tag">Web</span>
								</div>
								<p class="feat-tagline">{p.tagline}</p>
								<p class="feat-detail">{p.detail}</p>
								<div class="feat-links">
									<a href={p.url} target="_blank" rel="noreferrer" class="feat-visit">Visit site</a>
									<a href={p.src} target="_blank" rel="noreferrer" class="feat-src" aria-label={`${p.name} source on GitHub`}>
										<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 .5C5.7.5.5 5.6.5 12c0 5 3.3 9.3 7.9 10.8.6.1.8-.3.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.9 7.9-10.8C23.5 5.6 18.3.5 12 .5z"/></svg>
										<span>source</span>
									</a>
								</div>
							</div>
						</div>
					))}
				</div>

				<ul class="proj-list">
					{iosProjects.map((p) => (
						<li>
							<span class="head">
								<span class="name">{p.name}</span>
								<span class="type">iOS</span>
							</span>
							<span class="desc">{p.desc}</span>
							<span class="src-group">
								<a href={p.url} target="_blank" rel="noreferrer" class="src-appstore">{p.urlLabel}</a>
								<a href={p.src} target="_blank" rel="noreferrer" class="src" aria-label={`${p.name} source on GitHub`}>
									<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 .5C5.7.5.5 5.6.5 12c0 5 3.3 9.3 7.9 10.8.6.1.8-.3.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.9 7.9-10.8C23.5 5.6 18.3.5 12 .5z"/></svg>
								</a>
							</span>
						</li>
					))}
				</ul>
			</section>

			<section class="section">
				<h2>Recent writing</h2>
				<div class="writing-wrap">
					<div class="post-list">
						{latestPosts.map((post) => {
							const isBook = post.data.category === 'Books';
							const readTime = getReadTime(post.body);
							return (
								<a href={`/blog/${post.id}/`} class="card">
									{post.data.heroImage && (
										isBook ? (
											<div class="book-cover">
												<div class="book-shadow"></div>
												<div class="book-pages">
													<div class="book-page"></div>
													<div class="book-page"></div>
													<div class="book-page"></div>
												</div>
												<div class="book-front">
													<Image src={post.data.heroImage} alt={post.data.title} width={200} height={300} />
												</div>
											</div>
										) : (
											<div class="thumb">
												<Image src={post.data.heroImage} alt="" width={320} height={200} />
											</div>
										)
									)}
									<div class="body">
										<h3>{post.data.title}</h3>
										{isBook && post.data.author && <p class="author">by {post.data.author}</p>}
										<p class="desc">{post.data.description}</p>
										<div class="foot">
											{post.data.category && <span class="cat">{post.data.category}</span>}
											<span class="dot">&middot;</span>
											<FormattedDate date={post.data.pubDate} />
											<span class="dot">&middot;</span>
											<span>{readTime} min</span>
											{post.data.rating && (
												<span class="rating-wrap">
													<span class="dot">&middot;</span>
													<StarRating rating={post.data.rating} size={14} />
												</span>
											)}
										</div>
									</div>
								</a>
							);
						})}
					</div>
					<div class="fade-mask"></div>
				</div>
				<a href="/blog" class="read-more">Read all posts <span aria-hidden="true">→</span></a>
			</section>

			<section class="section">
				<h2>Interests</h2>
				<div class="gear-wrap">
					<div class="gear-preview">
						{gearPreview.map((g) => (
							<div class="g-card">
								<div class="g-photo"><img src={g.img} alt={g.name} loading="lazy" /></div>
								<div class="g-meta">
									<h3>{g.name}</h3>
									<p>{g.meta}</p>
								</div>
							</div>
						))}
					</div>
					<div class="fade-mask"></div>
				</div>
				<a href="/interests" class="read-more">Explore interests <span aria-hidden="true">→</span></a>
			</section>

			<section class="section">
				<h2>Contact</h2>
				<div class="social-row">
					<a href="https://github.com/ZigaoWang" target="_blank" rel="noreferrer" class="social">
						<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 .5C5.7.5.5 5.6.5 12c0 5 3.3 9.3 7.9 10.8.6.1.8-.3.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.9 7.9-10.8C23.5 5.6 18.3.5 12 .5z"/></svg>
						<span>GitHub</span>
					</a>
					<a href="https://x.com/zigaow" target="_blank" rel="noreferrer" class="social">
						<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
						<span>Twitter</span>
					</a>
					<a href="https://www.instagram.com/zigaowang24/" target="_blank" rel="noreferrer" class="social">
						<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
						<span>Instagram</span>
					</a>
					<a href="mailto:a@zigao.wang" class="social">
						<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="4.5" width="19" height="15" rx="0.5"/><path d="M2.5 6l9.5 7 9.5-7"/></svg>
						<span>Email</span>
					</a>
				</div>
			</section>
		</main>

		<Footer />

		<script is:inline>
			document.getElementById('play-pron')?.addEventListener('click', () => {
				const a = document.getElementById('pron-audio');
				if (a) { a.currentTime = 0; a.play(); }
			});
		</script>
	</body>
</html>

<style>
	.hero {
		position: relative;
		height: 680px;
		background: url('/bg.jpg') center 38% / cover no-repeat;
		display: flex;
		align-items: flex-end;
		overflow: hidden;
	}
	.hero-overlay {
		position: absolute;
		top: 0; right: 0; bottom: 0; left: 0;
		background:
			radial-gradient(ellipse at 25% 95%, rgba(0,0,0,0.55) 0%, transparent 65%),
			linear-gradient(180deg, rgba(0,0,0,0.08) 0%, rgba(0,0,0,0.5) 100%);
	}
	.hero-fade {
		position: absolute;
		bottom: 0; left: 0; right: 0;
		height: 140px;
		background: linear-gradient(to bottom, transparent, var(--bg));
		z-index: 1;
	}
	.hero-content {
		position: relative;
		z-index: 2;
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 0 var(--px) 2.5rem;
		width: 100%;
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 2rem;
	}
	.hero-text { flex: 1; min-width: 0; }
	.profile-pic {
		width: 140px;
		height: 140px;
		border-radius: 0;
		object-fit: cover;
		flex-shrink: 0;
		display: block;
	}
	.hero-content h1 {
		color: #fff;
		font-family: var(--font-hand);
		font-weight: 400;
		font-size: 4.4rem;
		line-height: 1.1;
		letter-spacing: 0;
		margin: 0 0 1.3rem;
		text-shadow: 0 2px 20px rgba(0,0,0,0.5);
	}
	.pron {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		color: rgba(255,255,255,0.78);
		font-size: 0.85rem;
		margin: 0 0 0.4rem;
		text-shadow: 0 1px 6px rgba(0,0,0,0.4);
	}
	.play-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 22px;
		height: 22px;
		padding: 0;
		background: none;
		border: none;
		color: rgba(255,255,255,0.7);
		cursor: pointer;
	}
	.play-btn:hover { color: #fff; }
	.play-btn svg { width: 14px; height: 14px; }
	.tagline {
		color: rgba(255,255,255,0.92);
		font-size: 1.05rem;
		max-width: 480px;
		margin: 0;
		text-shadow: 0 1px 6px rgba(0,0,0,0.4);
		line-height: 1.55;
	}

	main { padding-top: 2.25rem; padding-bottom: 3rem; }

	.section {
		padding-top: 2.5rem;
		border-top: 1px solid var(--border);
	}
	.section:first-child {
		padding-top: 0;
		border-top: none;
	}
	.section + .section { margin-top: 2.5rem; }

	h2 {
		font-family: var(--font-serif);
		font-weight: 400;
		font-size: 1.5rem;
		letter-spacing: -0.015em;
		margin: 0 0 1.1rem;
	}

	.sect-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.1rem;
	}
	.sect-head h2 { margin: 0; }
	.more { font-size: 0.92rem; color: var(--text-secondary); }
	.more:hover { color: var(--text); }

	.proj-featured {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		margin-bottom: 2rem;
	}
	.feat-card {
		background: var(--surface);
		border: 1px solid var(--border);
		display: flex;
		flex-direction: column;
		position: relative;
		transition: background 0.15s, border-color 0.15s;
	}
	.feat-card-link {
		position: absolute;
		inset: 0;
		z-index: 0;
	}
	.feat-card:hover {
		background: var(--surface-hover);
		border-color: #2a2a2a;
	}
	.feat-img {
		width: 100%;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: #111;
		border-bottom: 1px solid var(--border);
	}
	.feat-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.feat-body {
		padding: 1.1rem 1.25rem 1.15rem;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		flex: 1;
	}
	.feat-title-row {
		display: flex;
		align-items: baseline;
		gap: 0.55rem;
	}
	.feat-name {
		font-family: var(--font-serif);
		font-size: 1.25rem;
		font-weight: 400;
		color: var(--text);
	}
	.feat-tag {
		font-size: 0.75rem;
		color: var(--text-secondary);
		letter-spacing: 0.04em;
	}
	.feat-tagline {
		font-size: 0.95rem;
		font-weight: 500;
		color: var(--text);
		line-height: 1.45;
		margin: 0;
	}
	.feat-detail {
		font-size: 0.83rem;
		color: var(--text-secondary);
		line-height: 1.6;
		margin: 0;
	}
	.feat-links {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-top: auto;
		padding-top: 0.5rem;
		position: relative;
		z-index: 1;
	}
	.feat-visit {
		display: inline-flex;
		align-items: center;
		font-size: 0.82rem;
		color: var(--text-secondary);
		text-decoration: none;
	}
	.feat-visit:hover { color: var(--text); }
	.feat-src {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		font-size: 0.82rem;
		color: var(--text-secondary);
		text-decoration: none;
	}
	.feat-src:hover { color: var(--text); }
	.feat-src svg { width: 14px; height: 14px; display: block; }

	.proj-secondary-heading {
		font-size: 0.8rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--text-secondary);
		margin: 0 0 0.75rem;
	}

	.proj-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: max-content max-content 1fr max-content;
		column-gap: 1.5rem;
		row-gap: 0.25rem;
		align-items: baseline;
		font-size: 0.9rem;
		color: var(--text);
	}
	.proj-list li { display: contents; }
	.proj-list .head { display: contents; }
	.proj-list .type {
		color: var(--text-secondary);
		font-size: 0.82rem;
		font-variant-numeric: tabular-nums;
	}
	.proj-list .desc { color: var(--text-secondary); }
	.proj-list .src-group {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		align-self: center;
	}
	.proj-list .name {
		font-family: var(--font-serif);
		font-weight: 400;
		font-size: 1.15rem;
		color: var(--text);
		text-decoration: none;
	}
	.proj-list .src-appstore {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		font-size: 0.82rem;
		color: var(--text-secondary);
		text-decoration: none;
		white-space: nowrap;
		min-width: 5.5em;
	}
	.proj-list .src-appstore:hover { color: var(--text); }
	.proj-list .src {
		display: flex;
		align-items: center;
		color: var(--text-secondary);
		line-height: 0;
	}
	.proj-list .src:hover { color: var(--text); }
	.proj-list .src svg { width: 16px; height: 16px; display: block; }

	@media (max-width: 600px) {
		.proj-featured { grid-template-columns: 1fr; }
		.proj-list { display: flex; flex-direction: column; }
		.proj-list li {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.15rem 0.6rem;
			padding: 0.7rem 0;
		}
		.proj-list .head {
			display: flex;
			align-items: center;
			gap: 0.4rem;
			flex: 1;
			order: 1;
		}
		.proj-list .src-group {
			order: 2;
			flex-direction: row;
			gap: 0.5rem;
			align-items: center;
		}
		.proj-list .desc {
			order: 3;
			width: 100%;
			font-size: 0.84rem;
			color: var(--text-secondary);
			line-height: 1.5;
		}
		.proj-list .type { font-size: 0.8rem; }
