---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Lightbox from '../components/Lightbox.astro';
import StarRating from '../components/StarRating.astro';

type Props = CollectionEntry<'blog'>['data'] & { readTime?: number };

const { title, description, pubDate, updatedDate, category, tags, rating, author, heroImage, readTime } = Astro.props;
const isBook = category === 'Books';
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage?.src} />
	</head>
	<body>
		<Header />

		<!-- Mobile TOC bar -->
		<div class="mob-toc" id="mob-toc">
			<button class="mob-toc-btn" id="mob-toc-btn">
				<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 4h12M2 8h8M2 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
				<span id="mob-toc-label">On this page</span>
				<svg class="mob-toc-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 4.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
			</button>
			<div class="mob-toc-list" id="mob-toc-list"></div>
		</div>

		<div class="page-wrap">
			<main>
				<article>
					<a href="/blog" class="back">&larr; All posts</a>

					{isBook && heroImage ? (
						<header class="book-header">
							<div class="book-cover-wrap">
								<div class="book-cover-shadow"></div>
								<div class="book-cover-pages">
									<div class="book-cover-page"></div>
									<div class="book-cover-page"></div>
									<div class="book-cover-page"></div>
								</div>
								<div class="book-cover-front">
									<Image src={heroImage} alt={title} width={320} height={480} />
								</div>
							</div>
							<div class="book-meta">
								<div class="meta">
									{category && <span>{category}</span>}
									<span class="dot">&middot;</span>
									<FormattedDate date={pubDate} />
									{readTime && (
										<span>&middot; {readTime} min read</span>
									)}
								</div>
								<h1>{title}</h1>
								{author && <p class="author">by {author}</p>}
								{description && <p class="desc">{description}</p>}
								{rating && <StarRating rating={rating} />}
							</div>
						</header>
					) : (
						<header class="post-header">
							<div class="meta">
								{category && <span>{category}</span>}
								{category && <span class="dot">&middot;</span>}
								<FormattedDate date={pubDate} />
								{readTime && (
									<span>&middot; {readTime} min read</span>
								)}
								{updatedDate && (
									<span class="updated">
										&middot; Updated <FormattedDate date={updatedDate} />
									</span>
								)}
							</div>
							<h1>{title}</h1>
							{description && <p class="desc">{description}</p>}
						</header>
					)}

					<div class="prose" id="prose-content">
						<slot />
					</div>
					{tags && tags.length > 0 && (
						<div class="tags">
							{tags.map((tag) => (
								<span class="tag">#{tag}</span>
							))}
						</div>
					)}
				</article>
			</main>
		</div>

		<!-- Desktop TOC -->
		<aside class="toc" id="toc">
			<nav id="toc-nav">
				<p class="toc-label">On this page</p>
				<div class="toc-links" id="toc-links"></div>
				<div class="toc-footer">
					<div class="toc-progress"><div class="toc-progress-fill" id="toc-progress"></div></div>
					<button class="toc-top" id="toc-top">
						<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 10V2m0 0L2 6m4-4l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
						Back to top
					</button>
				</div>
			</nav>
		</aside>

		<Footer />
		<Lightbox />

		<script>
			const prose = document.getElementById('prose-content');
			const tocLinks = document.getElementById('toc-links');
			const toc = document.getElementById('toc');
			const progressFill = document.getElementById('toc-progress');
			const topBtn = document.getElementById('toc-top');
			const mobToc = document.getElementById('mob-toc');
			const mobBtn = document.getElementById('mob-toc-btn');
			const mobList = document.getElementById('mob-toc-list');
			const mobLabel = document.getElementById('mob-toc-label');

			if (prose && tocLinks && toc && mobToc && mobBtn && mobList && mobLabel) {
				const headings = prose.querySelectorAll<HTMLElement>('h2, h3');

				if (headings.length >= 3) {
					// Build link HTML
					const html = Array.from(headings).map((h) =>
						`<a href="#${h.id}" class="${h.tagName === 'H3' ? 'sub' : ''}">${h.textContent}</a>`
					).join('');
					tocLinks.innerHTML = html;
					mobList.innerHTML = html;

					const desktopLinks = tocLinks.querySelectorAll('a');
					const mobileLinks = mobList.querySelectorAll('a');
					const allLinks = [...desktopLinks, ...mobileLinks];

					// Scroll spy
					let currentSection = '';
					const observer = new IntersectionObserver((entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								currentSection = entry.target.id;
								allLinks.forEach((a) => a.classList.toggle('active', a.getAttribute('href') === `#${currentSection}`));
								// Auto-scroll desktop toc
								const active = tocLinks.querySelector('a.active');
								active?.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
								// Update mobile label to current h2
								const h = entry.target as HTMLElement;
								const label = h.tagName === 'H2' ? h.textContent : null;
								if (label) mobLabel.textContent = label;
							}
						}
					}, { rootMargin: '-80px 0px -75% 0px' });
					headings.forEach((h) => observer.observe(h));

					// Reading progress
					if (progressFill) {
						const update = () => {
							const rect = prose.getBoundingClientRect();
							const pct = Math.min(100, Math.max(0, -rect.top / (prose.scrollHeight - window.innerHeight) * 100));
							(progressFill as HTMLElement).style.width = pct + '%';
						};
						window.addEventListener('scroll', update, { passive: true });
						update();
					}

					// Back to top
					topBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

					// Smooth scroll with offset for all links
					allLinks.forEach((a) => {
						a.addEventListener('click', (e) => {
							e.preventDefault();
							const id = a.getAttribute('href')!.slice(1);
							const el = document.getElementById(id);
							if (el) {
								window.scrollTo({ top: el.getBoundingClientRect().top + window.scrollY - 80, behavior: 'smooth' });
							}
							// Close mobile dropdown
							mobToc.classList.remove('open');
						});
					});

					// Mobile toggle
					mobBtn.addEventListener('click', () => mobToc.classList.toggle('open'));
					// Close on outside click
					document.addEventListener('click', (e) => {
						if (!mobToc.contains(e.target as Node)) mobToc.classList.remove('open');
					});
				} else {
					toc.remove();
					mobToc.remove();
				}
			}
		</script>
	</body>
</html>

<style>
	.page-wrap {
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 0 var(--px);
	}
	main {
		min-width: 0;
		padding: 2.5rem 0 3rem;
	}

	/* ══════════════════════════════
	   Desktop TOC — fixed right
	   ══════════════════════════════ */
	.toc {
		position: fixed;
		top: 0;
		left: calc(50% + var(--max-w) / 2 + var(--px));
		width: 200px;
		height: 100vh;
		display: flex;
		flex-direction: column;
	}
	.toc nav {
		display: flex;
		flex-direction: column;
		padding: 6rem 0 2rem 1.5rem;
		height: 100%;
	}
	.toc-label {
		font-size: 0.65rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--text-secondary);
		opacity: 0.5;
		margin: 0 0 0.6rem;
		padding-left: 0.75rem;
		flex-shrink: 0;
	}
	.toc-links {
		display: flex;
		flex-direction: column;
		overflow-y: auto;
		flex: 1;
		min-height: 0;
		border-left: 1px solid var(--border);
	}
	.toc-links::-webkit-scrollbar { width: 0; }
	.toc :global(a) {
		font-size: 0.76rem;
		line-height: 1.4;
		color: var(--text-secondary);
		text-decoration: none;
		padding: 0.28rem 0.75rem;
		margin-left: -1px;
		border-left: 2px solid transparent;
		transition: color 0.2s, border-color 0.2s, opacity 0.2s;
		opacity: 0.55;
	}
	.toc :global(a:hover) {
		color: var(--text);
		opacity: 1;
	}
	.toc :global(a.active) {
		color: var(--text);
		border-left-color: var(--text);
		opacity: 1;
	}
	.toc :global(a.sub) {
		padding-left: 1.5rem;
		font-size: 0.7rem;
	}
	.toc-footer {
		flex-shrink: 0;
		padding-left: 0.75rem;
		margin-top: 1rem;
	}
	.toc-progress {
		height: 2px;
		background: var(--border);
		border-radius: 1px;
		overflow: hidden;
	}
	.toc-progress-fill {
		height: 100%;
		width: 0%;
		background: var(--text-secondary);
		border-radius: 1px;
		transition: width 0.15s ease;
	}
	.toc-top {
		display: flex;
		align-items: center;
		margin-top: 0.6rem;
		padding: 0;
		background: none;
		border: none;
		color: var(--text-secondary);
		font-size: 0.68rem;
		font-family: inherit;
		cursor: pointer;
		opacity: 0.5;
		transition: opacity 0.15s, color 0.15s;
	}
	.toc-top:hover { opacity: 1; color: var(--text); }
	.toc-top > * + * { margin-left: 0.35rem; }

	/* ══════════════════════════════
	   Mobile TOC — sticky bar
	   ══════════════════════════════ */
	.mob-toc {
		display: none;
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(10,10,10,0.95);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
	}
	.mob-toc-btn {
		display: flex;
		align-items: center;
		width: 100%;
		padding: 0.7rem var(--px);
		background: none;
		border: none;
		color: var(--text-secondary);
		font-size: 0.82rem;
		font-family: inherit;
		cursor: pointer;
	}
	.mob-toc-btn > * + * { margin-left: 0.45rem; }
	.mob-toc-btn svg:first-child { opacity: 0.5; flex-shrink: 0; }
	.mob-toc-btn :global(#mob-toc-label) {
		flex: 1;
		text-align: left;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.mob-toc-chevron {
		flex-shrink: 0;
		opacity: 0.4;
		transition: transform 0.2s ease;
	}
	.mob-toc.open .mob-toc-chevron { transform: rotate(180deg); }
	.mob-toc-list {
		display: none;
		flex-direction: column;
		max-height: 55vh;
		overflow-y: auto;
		padding: 0 var(--px) 0.75rem;
		-webkit-overflow-scrolling: touch;
	}
	.mob-toc.open .mob-toc-list { display: flex; }
	.mob-toc-list :global(a) {
		font-size: 0.85rem;
		line-height: 1.4;
		color: var(--text-secondary);
		text-decoration: none;
		padding: 0.5rem 0 0.5rem 0.75rem;
		border-left: 2px solid var(--border);
		transition: color 0.15s, border-color 0.15s;
	}
	.mob-toc-list :global(a:hover),
	.mob-toc-list :global(a.active) {
		color: var(--text);
		border-left-color: var(--text);
	}
	.mob-toc-list :global(a.sub) {
		padding-left: 1.75rem;
		font-size: 0.8rem;
	}

	/* ══════════════════════════════
	   Back link
	   ══════════════════════════════ */
	.back {
		display: inline-block;
		font-size: 0.85rem;
		color: var(--text-secondary);
		text-decoration: none;
		margin-bottom: 2rem;
		transition: color 0.15s;
	}
	.back:hover { color: var(--text); }

	/* ══════════════════════════════
	   Regular post header
	   ══════════════════════════════ */
	.post-header {
		margin-bottom: 2.5rem;
		padding-bottom: 1.75rem;
		border-bottom: 1px solid var(--border);
	}
	.post-header h1 {
		margin: 0.25rem 0 0.4rem;
		font-size: 2.15rem;
		line-height: 1.2;
		letter-spacing: -0.02em;
	}

	/* ══════════════════════════════
	   Book header with 3D cover
	   ══════════════════════════════ */
	.book-header {
		display: flex;
		align-items: flex-start;
		margin-bottom: 2.5rem;
		padding-bottom: 1.75rem;
		border-bottom: 1px solid var(--border);
	}
	.book-cover-wrap { margin-right: 2rem; }
	.book-header h1 {
		margin: 0.25rem 0 0.3rem;
		font-size: 2.15rem;
		line-height: 1.2;
		letter-spacing: -0.02em;
	}
	.book-meta { flex: 1; min-width: 0; }

	.book-cover-wrap {
		position: relative;
		flex-shrink: 0;
		width: 140px;
		perspective: 1200px;
	}
	.book-cover-shadow {
		position: absolute;
		top: 6px; right: -6px; bottom: -8px; left: -6px;
		background: rgba(0,0,0,0.35);
		filter: blur(14px);
		border-radius: 4px;
		opacity: 0.7;
		transition: all 500ms cubic-bezier(0.16, 1, 0.3, 1);
	}
	.book-cover-pages { position: absolute; top: 0; right: 0; bottom: 0; left: 0; border-radius: 3px; }
	.book-cover-page {
		position: absolute;
		background: #1a1a1a;
		border: 1px solid rgba(255,255,255,0.04);
		border-radius: 3px;
		transition: transform 500ms cubic-bezier(0.2, 0.9, 0.2, 1);
	}
	.book-cover-page:nth-child(1) { top: 2px; right: 1px; bottom: 2px; left: auto; width: 100%; }
	.book-cover-page:nth-child(2) { top: 4px; right: 3px; bottom: 4px; left: auto; width: 100%; }
	.book-cover-page:nth-child(3) { top: 6px; right: 5px; bottom: 6px; left: auto; width: 100%; }
	.book-cover-front {
		position: relative;
		transform-origin: left center;
		transform-style: preserve-3d;
		border-radius: 3px;
		overflow: hidden;
		box-shadow: 0 2px 8px rgba(0,0,0,0.3);
		transition: transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
	}
	.book-cover-front :global(img) {
		display: block;
		width: 140px;
		height: auto;
		border-radius: 3px;
	}

	/* ══════════════════════════════
	   Shared
	   ══════════════════════════════ */
	.author { font-size: 1rem; color: var(--text-secondary); margin: 0 0 0.5rem; }
	.desc { color: var(--text-secondary); font-size: 1rem; line-height: 1.65; margin: 0 0 0.75rem; }
	.meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		color: var(--text-secondary);
		font-size: 0.85rem;
	}
	.meta > * { margin-right: 0.5rem; }
	.dot { opacity: 0.4; }
	.updated { font-style: italic; }

	.tags {
		display: flex;
		flex-wrap: wrap;
		margin-top: 2rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--border);
	}
	.tags > * { margin-right: 0.5rem; margin-bottom: 0.5rem; }
	.tag {
		font-size: 0.8rem;
		color: var(--text-secondary);
		background: rgba(255,255,255,0.05);
		padding: 0.25rem 0.6rem;
		border-radius: 4px;
	}

	.prose { line-height: 1.8; font-size: 1rem; }
	.prose :global(h2) { margin-top: 2.5rem; margin-bottom: 0.6rem; scroll-margin-top: 5rem; }
	.prose :global(h3) { margin-top: 1.75rem; margin-bottom: 0.5rem; scroll-margin-top: 5rem; }
	.prose :global(p) { margin-bottom: 1.2rem; }
	.prose :global(ul),
	.prose :global(ol) { margin-bottom: 1.2rem; padding-left: 1.5rem; }
	.prose :global(li) { margin-bottom: 0.35rem; }
	.prose :global(figure) { margin: 2rem 0; }
	.prose :global(.photo-small) { max-width: 400px; margin-left: auto; margin-right: auto; }
	.prose :global(pre) { margin: 1.75rem 0; }
	.prose :global(hr) { margin: 2.5rem 0; }

	/* ══════════════════════════════
	   Responsive
	   ══════════════════════════════ */
	@media (max-width: 1200px) {
		.toc { display: none; }
		.mob-toc { display: block; }
	}

	@media (max-width: 600px) {
		.book-header {
			display: grid;
			grid-template-columns: 1fr;
			grid-row-gap: 1.25rem;
			padding: 1.5rem 1.1rem 1.6rem;
			border: 1px solid rgba(255,255,255,0.06);
			border-radius: 18px;
			background: rgba(255,255,255,0.02);
			box-shadow:
				inset 0 1px 0 rgba(255,255,255,0.03),
				0 16px 36px rgba(0,0,0,0.16);
		}
		.book-cover-wrap {
			width: clamp(176px, 56vw, 212px);
			margin: 0 auto;
		}
		.book-cover-shadow {
			top: 8px; right: -8px; bottom: -12px; left: -8px;
			filter: blur(16px);
			opacity: 0.78;
		}
		.book-cover-front {
			border: 1px solid rgba(255,255,255,0.04);
			box-shadow: 0 12px 28px rgba(0,0,0,0.26);
		}
		.book-cover-front :global(img) { width: 100%; }
		.book-meta {
			padding: 1rem 0 0;
			border-top: 1px solid rgba(255,255,255,0.06);
			text-align: left;
		}
		.meta {
			justify-content: flex-start;
			font-size: 0.78rem;
			letter-spacing: 0.02em;
			text-transform: uppercase;
		}
		.meta > * { margin-right: 0.5rem; margin-bottom: 0.35rem; }
		.book-header h1 {
			margin-top: 0.45rem;
			font-size: 1.72rem;
			line-height: 1.16;
		}
		.author {
			margin: 0 0 0.55rem;
			font-size: 0.96rem;
		}
		.desc {
			font-size: 0.94rem;
			line-height: 1.6;
			margin-bottom: 0.9rem;
		}
		.star-rating { justify-content: flex-start; }
	}

	@media (hover: hover) and (pointer: fine) {
		.book-cover-wrap:hover .book-cover-shadow {
			transform: translateY(4px);
			opacity: 0.9;
			filter: blur(18px);
		}
		.book-cover-wrap:hover .book-cover-page:nth-child(1) { transform: translateX(3px); }
		.book-cover-wrap:hover .book-cover-page:nth-child(2) { transform: translateX(6px); }
		.book-cover-wrap:hover .book-cover-page:nth-child(3) { transform: translateX(9px); }
		.book-cover-wrap:hover .book-cover-front { transform: rotateY(-18deg); }
	}

	@media (prefers-reduced-motion: reduce) {
		.book-cover-shadow, .book-cover-front, .book-cover-page { transition: none; }
	}
</style>
