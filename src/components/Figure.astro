---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	src: ImageMetadata;
	alt: string;
	caption?: string;
	width?: number;
	class?: string;
}

const { src, alt, caption, width = 640, class: className } = Astro.props;
---

<figure class:list={[className]}>
	<a href={src.src} class="lightbox-trigger" data-lightbox>
		<Image src={src} alt={alt} width={width} />
	</a>
	{caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
	figure {
		margin: 1.75em 0;
		padding: 0;
		text-align: center;
	}
	.lightbox-trigger {
		display: inline-block;
		cursor: zoom-in;
		border: none;
		text-decoration: none;
		border-radius: 10px;
		overflow: hidden;
	}
	.lightbox-trigger :global(img) {
		display: block;
		border-radius: 10px;
		transition: transform 0.3s, opacity 0.2s;
		margin: 0 auto;
	}
	.lightbox-trigger:hover :global(img) {
		transform: scale(1.015);
		opacity: 0.92;
	}
	figcaption {
		margin-top: 0.6em;
		font-size: 0.82em;
		color: var(--text-secondary);
		text-align: center;
		line-height: 1.45;
		font-style: italic;
		opacity: 0.7;
	}
</style>
