---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo">{SITE_TITLE}</a>
		<div class="links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Posts</HeaderLink>
			<HeaderLink href="https://zigao.wang" target="_blank" rel="noreferrer">About</HeaderLink>
			<a
				href="https://github.com/ZigaoWang/blog.zigao.wang"
				target="_blank"
				rel="noreferrer"
				class="github-link"
				aria-label="GitHub repository"
			>
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path
						fill="currentColor"
						d="M12 2C6.477 2 2 6.484 2 12.017c0 4.426 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483
						0-.237-.008-.866-.013-1.699-2.782.605-3.369-1.344-3.369-1.344-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608
						1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.091-.647.349-1.088.635-1.338-2.22-.253-4.555-1.113-4.555-4.951
						0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337
						1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855
						0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"
					/>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		border-bottom: 1px solid var(--border);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 0.85rem var(--px);
	}
	.logo {
		font-family: var(--font-serif);
		font-size: 1.05rem;
		font-weight: 400;
		color: var(--text);
		text-decoration: none;
		letter-spacing: -0.02em;
	}
	.logo:hover { opacity: 0.8; }
	.links {
		display: flex;
		align-items: center;
		gap: 0.15rem;
	}
	.github-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border-radius: 6px;
		color: #aaa;
		text-decoration: none;
		transition: color 0.15s, background 0.15s;
	}
	.github-link:hover {
		color: var(--text);
		background: rgba(255, 255, 255, 0.05);
	}
	.github-link svg {
		width: 1rem;
		height: 1rem;
	}
</style>
