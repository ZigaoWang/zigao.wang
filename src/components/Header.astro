---
import { SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const links = [
	{ label: 'Home', href: '/' },
	{ label: 'Posts', href: '/blog' },
	{ label: 'Interests', href: '/interests' },
];

function isActive(href: string): boolean {
	if (href === '/') return pathname === '/' || pathname === '';
	if (href === pathname) return true;
	if (pathname.startsWith(href + '/')) return true;
	return false;
}
---

<header>
	<nav>
		<a href="/" class="logo">{SITE_TITLE}</a>
		<div class="links">
			{links.map((l) => (
				<a href={l.href} class:list={['nav-link', { active: isActive(l.href) }]}>{l.label}</a>
			))}
		</div>
	</nav>
</header>

<style>
	header { border-bottom: 1px solid var(--border); }
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 0.85rem var(--px);
	}
	.logo {
		font-family: var(--font-hand);
		font-size: 1.75rem;
		font-weight: 400;
		color: var(--text);
		text-decoration: none;
		letter-spacing: 0;
		line-height: 1;
	}
	.logo:hover { opacity: 0.8; }
	.links { display: flex; align-items: center; }
	.links > * + * { margin-left: 0.15rem; }
	.nav-link {
		display: inline-block;
		padding: 0.3rem 0.6rem;
		text-decoration: none;
		color: #aaa;
		font-size: 0.88rem;
		font-weight: 450;
	}
	.nav-link:hover { color: var(--text); }
	.nav-link.active { color: var(--text); }

	@media (max-width: 520px) {
		nav { padding: 0.75rem 1rem; }
		.nav-link { padding: 0.3rem 0.45rem; font-size: 0.82rem; }
		.logo { font-size: 1.55rem; }
	}
</style>
