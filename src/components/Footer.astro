---
const today = new Date();
---

<footer>
	<span>&copy; {today.getFullYear()} <a href="https://zigao.wang" target="_blank" rel="noreferrer">Zigao Wang</a></span>
</footer>
<style>
	footer {
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 2rem var(--px) 2rem;
		border-top: 1px solid var(--border);
		text-align: center;
		font-size: 0.75rem;
		color: var(--text-secondary);
	}
	a {
		color: inherit;
		text-decoration: none;
	}
	a:hover {
		text-decoration: underline;
	}
</style>
