---
const today = new Date();
---

<footer>
	<div class="meta">
		<span>&copy; {today.getFullYear()} <span class="sig">Zigao Wang</span></span>
		<span class="sep" aria-hidden="true">·</span>
		<a href="https://github.com/ZigaoWang/zigao.wang" target="_blank" rel="noreferrer" class="src-link" aria-label="View source on GitHub">
			<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 .5C5.7.5.5 5.6.5 12c0 5 3.3 9.3 7.9 10.8.6.1.8-.3.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.9 7.9-10.8C23.5 5.6 18.3.5 12 .5z"/></svg>
			<span>View source</span>
		</a>
	</div>
	<div class="flag-strip">
		<a href="https://info.flagcounter.com/FHXI" target="_blank" rel="noreferrer" aria-label="Visitor counter by country">
			<img class="flag-desktop" src="https://s01.flagcounter.com/count/FHXI/bg_0c0c0c/txt_888888/border_1F1F1F/columns_6/maxflags_24/viewers_Hello+from/labels_1/pageviews_1/flags_0/percent_0/" alt="Visitors by country" onerror="this.closest('.flag-strip').style.display='none'" onload="if(this.naturalWidth<10)this.closest('.flag-strip').style.display='none'" />
			<img class="flag-mobile" src="https://s01.flagcounter.com/count/FHXI/bg_0c0c0c/txt_888888/border_1F1F1F/columns_4/maxflags_12/viewers_Hello+from/labels_1/pageviews_1/flags_0/percent_0/" alt="Visitors by country" onerror="this.closest('.flag-strip').style.display='none'" onload="if(this.naturalWidth<10)this.closest('.flag-strip').style.display='none'" />
		</a>
	</div>
</footer>
<style>
	footer {
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 2.5rem var(--px) 2.5rem;
		border-top: 1px solid var(--border);
		text-align: center;
	}
	.meta {
		font-size: 0.85rem;
		color: var(--text-secondary);
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0.6rem;
		flex-wrap: wrap;
	}
	.sig {
		font-family: var(--font-hand);
		font-size: 1.15rem;
		color: var(--text-secondary);
		margin-left: 0.15rem;
		vertical-align: -1px;
	}
	.meta a {
		color: var(--text);
		text-decoration: none;
	}
	.meta a:hover { color: var(--text-secondary); }
	.src-link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
	}
	.src-link svg {
		width: 14px;
		height: 14px;
		display: block;
	}
	.sep { opacity: 0.5; }

	.flag-strip {
		display: flex;
		justify-content: center;
		margin-top: 3.5rem;
	}
	.flag-strip a {
		display: block;
		width: 100%;
		max-width: 460px;
		line-height: 0;
	}
	.flag-strip img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 0;
	}
	.flag-mobile { display: none !important; }

	@media (max-width: 600px) {
		footer { padding: 2rem var(--px) 2rem; }
		.flag-strip { margin-top: 2.5rem; }
		.flag-strip a { max-width: 100%; }
		.flag-desktop { display: none !important; }
		.flag-mobile { display: block !important; }
	}
</style>
